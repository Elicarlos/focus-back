# Configuração de Banco de Dados
# Em produção no Docker, o docker-compose utilizará o PostgreSQL automaticamente.
# Exemplo local: postgresql://username:password@localhost:5432/dbname
DATABASE_URL=postgresql://seu_usuario:sua_senha@seu_ip:5432/seu_banco

# Google OAuth Credentials (utilizados para validar logins via Google no backend/frontend)
GOOGLE_CLIENT_ID=seu_google_client_id_aqui.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_google_client_secret_aqui

# Chave secreta de autenticação do backend para geração de JWT locais
SECRET_KEY=sua_chave_jwt_secreta_aqui

# Integrações Premium (Opcional - Stripe)
STRIPE_SECRET_KEY=sk_test_sua_chave_stripe_aqui
STRIPE_WEBHOOK_SECRET=whsec_seu_webhook_secret_aqui
STRIPE_PRO_PRICE_ID=price_seu_price_id_aqui

# Armazenamento em Nuvem (Opcional - MinIO/S3)
S3_ENDPOINT=https://seu-minio-endpoint.host
S3_ACCESS_KEY=seu_access_key
S3_SECRET_KEY=sua_secret_key
S3_BUCKET_NAME=seu_bucket_name
S3_REGION=us-east-1
S3_PUBLIC_URL=https://seu-minio-endpoint.host/seu-bucket-name
